rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only-Me gatekeeper — all access locked to the authorized owner UID.
    // The wildcarded sub-path covers the artifacts paths used by the app.
    match /artifacts/{appId}/users/{uid}/{document=**} {
      allow read, write: if
        request.auth != null &&
        request.auth.uid == uid;
    }

    // Authorized Users Whitelist
    match /authorized_users/{email} {
      // Any signed-in user can read their own authorization status
      allow read: if request.auth != null && request.auth.token.email.lower() == email.lower();
      
      // Only admins can write (add/modify/delete) documents in this collection
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/authorized_users/$(request.auth.token.email.lower())).data.role == 'admin';
    }
  }
}