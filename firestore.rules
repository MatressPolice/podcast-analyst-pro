rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only-Me gatekeeper — all access locked to the authorized owner UID.
    // The wildcarded sub-path covers the artifacts paths used by the app.
    match /artifacts/{appId}/users/{uid}/{document=**} {
      allow read, write: if
        request.auth != null &&
        request.auth.uid == uid;
    }
  }
}