# Vite reads variables prefixed with VITE_
# Copy this file to .env.local and fill in the values

# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Verified Identity Keys
# A comma-separated list of emails authorized for full app access.
VITE_AUTHORIZED_EMAILS=your_authorized_email@example.com

# Local Discovery Keys (Bypassing Cloud Functions for MVP speed)
VITE_TADDY_USER_ID=your_taddy_user_id
VITE_TADDY_API_KEY=your_taddy_api_key
VITE_ASSEMBLY_AI_API_KEY=your_assembly_ai_api_key
VITE_GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key
